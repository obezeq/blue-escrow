# Backend (apps/api) — read by docker compose api service via compose.yml.
# For the same keys when running the api outside docker, copy to apps/api/.env.

# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Database (postgres:18-alpine via docker compose db service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blue_escrow

# JWT (EdDSA PEM keys — generated in S03 user manual task)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# SIWE (EIP-4361)
COOKIE_DOMAIN=localhost
SIWE_DOMAIN=localhost:3000
SIWE_SCHEME=http

# Blockchain RPC (Alchemy URL set in S07 user manual task)
RPC_URL_ARBITRUM_SEPOLIA=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Frontend (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# Frontend (public) -- absolute site URL used for OG/Twitter image resolution
# via `metadataBase` in the root layout.
# - Dev: leave blank (falls back to http://localhost:3000).
# - Prod (Docker VPS): MUST be set at BUILD time in the Dockerfile (via ARG/ENV
#   before `next build`), because NEXT_PUBLIC_* values are inlined into the
#   static-prerendered HTML. Setting it only at container start is too late.
NEXT_PUBLIC_SITE_URL=

# Dev-only. LAN IPs / hostnames allowed to hit the Next.js dev server for HMR.
# Comma-separated. Unused in production (next build/start ignore this).
# Copy to apps/web/.env.local (gitignored) with your real LAN IP to test from
# your phone or other devices on the same network.
NEXT_DEV_ALLOWED_ORIGINS=

# Contract Addresses (set after deployment)
ESCROW_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=
MIDDLEMAN_REGISTRY_ADDRESS=
RECEIPT_NFT_ADDRESS=
SOULBOUND_NFT_ADDRESS=
