# Backend MVP env template — copy to apps/api/.env when running the api
# outside docker compose. Inside docker compose, the api reads vars from
# the repo-root .env via compose.yml (which has matching keys).

# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Database (matches docker compose db service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blue_escrow

# JWT (EdDSA PEM keys — generated in S03 user manual task)
# In development these can stay empty; env.ts substitutes a clearly-marked
# placeholder. In production they MUST be real or the api fails fast.
#
# Generate a fresh keypair with jose (paste output below; \n becomes literal):
#   node --input-type=module -e "import * as j from 'jose'; \
#     const {publicKey, privateKey} = await j.generateKeyPair('EdDSA'); \
#     console.log('JWT_PRIVATE_KEY=\"' + (await j.exportPKCS8(privateKey)).replace(/\n/g, '\\\\n') + '\"'); \
#     console.log('JWT_PUBLIC_KEY=\"'  + (await j.exportSPKI(publicKey)).replace(/\n/g, '\\\\n') + '\"');"
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# SIWE (EIP-4361)
COOKIE_DOMAIN=localhost
SIWE_DOMAIN=localhost:3000
SIWE_SCHEME=http

# Blockchain RPC (Alchemy URL set in S07 user manual task)
RPC_URL_ARBITRUM_SEPOLIA=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
