{
  "name": "@blue-escrow/api",
  "version": "0.0.0",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo node_modules",
    "prisma:generate": "prisma generate && tsx scripts/post-prisma-generate.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@acpr/rate-limit-postgresql": "^1.4.1",
    "@blue-escrow/config": "workspace:*",
    "@blue-escrow/types": "workspace:*",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prisma-json-types-generator": "^4.1.1",
    "ulid": "^3.0.0",
    "viem": "^2.21.0",
    "zod": "^3.24.0",
    "zod-openapi": "^5.0.0"
  },
  "devDependencies": {
    "@blue-escrow/eslint-config": "workspace:*",
    "@blue-escrow/tsconfig": "workspace:*",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.22.0",
    "execa": "^9.5.0",
    "fast-check": "^3.23.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^7.4.1",
    "supertest": "^7.0.0",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
