{
  "name": "@blue-escrow/api",
  "version": "0.0.0",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:seed": "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@blue-escrow/types": "workspace:*",
    "@blue-escrow/config": "workspace:*",
    "@prisma/client": "^7.4.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@blue-escrow/tsconfig": "workspace:*",
    "@blue-escrow/eslint-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.0.0",
    "prisma": "^7.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
